{
  "name": "midi-audio-player",
  "version": "2.0.0",
  "description": "Real MIDI playback in the browser — powered by Web Audio API and WebAudioFont.",
  "keywords": [
    "midi",
    "midi-player",
    "webaudio",
    "webaudiofont",
    "audio",
    "music",
    "browser-audio",
    "midi-js",
    "web-audio-api",
    "midi-playback"
  ],
  "homepage": "https://WebAudioFonts.github.io/",
  "bugs": {
    "url": "https://github.com/WebAudioFonts/midi-audio-player/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebAudioFonts/midi-audio-player.git"
  },
  "license": "MIT",
  "author": "Maxime Larrivée-Roy",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "unpkg": "./dist/midi-audio-player.min.js",
  "jsdelivr": "./dist/midi-audio-player.min.js",
  "files": [
    "dist",
    "bin",
    "src",
    "index.js",
    "index.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "script": "./dist/midi-audio-player.min.js"
    }
  },
  "types": "index.d.ts",
  "scripts": {
    "build": "node scripts/watch.js --build",
    "dev": "node scripts/watch.js",
    "sass:build": "sass site/:site/ --no-source-map",
    "sass:watch": "sass site/:site/ --no-source-map --watch",
    "serve:site": "browser-sync start --server --startPath /site/ --files \"site/**/*.html, site/**/*.css, site/**/*.js, dist/**/*.js\""
  },
  "dependencies": {
    "midi-player-js": "^2.0.17",
    "webaudiofontplayer": "^1.0.0"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "esbuild": "^0.28.0",
    "sass": "^1.100.0"
  },
  "engines": {
    "node": ">=18"
  }
}
